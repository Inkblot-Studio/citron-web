# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://citronos.com
# Billing & usage dashboard — separate subdomain app (citron-web-billing).
NEXT_PUBLIC_BILLING_URL=https://billing.citronos.com

# ── Identity (auth subdomain — separate system) ─────────────────────────────
# Where the Log in / Sign up buttons send users.
NEXT_PUBLIC_IDENTITY_URL=https://identity.citronos.com
# Server-side session validation endpoint. citron-web forwards the shared
# .citronos.com session cookie to `${IDENTITY_API_URL}/api/session` and
# expects `{ user: { id, email, name, workspace } }` on 200.
IDENTITY_API_URL=
# Name of the shared session cookie set by identity on `.citronos.com`.
SESSION_COOKIE_NAME=citron_session
# Set to "1" in local dev to preview account/usage pages with a fake session.
DEV_FAKE_SESSION=

# ── Stripe (use test keys until launch; swap for live keys to go live) ──────
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# or the dashboard webhook endpoint config.
STRIPE_WEBHOOK_SECRET=whsec_...
# Promo codes (e.g. CITRUS20) are Stripe coupons — create them in the
# dashboard; checkout has promotion codes enabled.

# ── Sales AI assistant (optional) ───────────────────────────────────────────
# When set, /api/assistant answers with Claude. When empty, a scripted
# assistant handles conversations at zero cost.
ANTHROPIC_API_KEY=

# ── Demo scheduling (optional) ──────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=

# ── Citron Platform API (citron-api) ─────────────────────────────────────
# When set, /api/usage serves live data and Stripe checkouts are
# provisioned through the platform backend. Unset = local mocks.
CITRON_API_URL=
CITRON_API_TOKEN=
